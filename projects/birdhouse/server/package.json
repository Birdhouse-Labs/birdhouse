{
  "name": "birdhouse-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch --env-file=../.env src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/server",
    "test": "NODE_ENV=test bun test",
    "test:watch": "NODE_ENV=test bun test --watch",
    "typecheck": "bun tsc --noEmit",
    "lint": "bunx biome check src tests && bun scripts/lint-custom.ts",
    "lint:custom": "bun scripts/lint-custom.ts",
    "lint:fix": "bunx biome check --write src tests",
    "check": "bun run lint && bun run typecheck && bun test && bun run build",
    "db:migrate-data": "bun scripts/db-migrate-data.ts",
    "db:migrate-down-data": "bun scripts/db-migrate-down-data.ts",
    "db:migrate-agents-db": "bun scripts/db-migrate-agents.ts",
    "db:migrate-down-agents-db": "bun scripts/db-migrate-down-agents.ts",
    "db:migrate-down-agents-all": "bun scripts/db-migrate-down-agents-all.ts",
    "agent-migration:new": "bun scripts/agent-migration-new.ts",
    "data-migration:new": "bun scripts/data-migration-new.ts"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.1.12",
    "eventsource": "^4.1.0",
    "hono": "^4.6.16",
    "hono-pino": "^0.10.3",
    "js-yaml": "^4.1.0",
    "kysely": "^0.28.11",
    "kysely-bun-sqlite": "^0.4.0",
    "nanoid": "^5.1.6",
    "pino": "^10.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/eventsource": "^3.0.0",
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.1.40",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
