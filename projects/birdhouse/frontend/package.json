{
  "name": "birdhouse-frontend",
  "version": "1.0.0",
  "description": "Birdhouse Playground Frontend",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "generate:themes": "node scripts/generate-themes.js",
    "generate:experiments": "node scripts/generate-experiments.js",
    "generate:favicons": "node scripts/generate-favicons.js",
    "validate:themes": "node scripts/validate-themes.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "test": "bun --bun vitest run --passWithNoTests",
    "test:watch": "bun --bun vitest",
    "check": "bun run generate:themes && bun run validate:themes && bun run typecheck && bun run lint && bun run lint:css && bun run test && bun run build",
    "fix": "biome check --write src",
    "update:posthog-vendor": "node scripts/update-posthog-vendor.js"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.0.3",
    "convert-to-oklch": "^1.2.8",
    "jsdom": "^27.3.0",
    "solid-devtools": "^0.34.3",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-declaration-strict-value": "^1.10.11",
    "stylelint-scss": "^6.13.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.3.0",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@corvu/tailwind": "^0.1.7",
    "@floating-ui/dom": "^1.7.4",
    "@opencode-ai/sdk": "^1.1.18",
    "@pierre/diffs": "^1.0.10",
    "@shikijs/monaco": "^4.0.2",
    "@solidjs/router": "^0.15.4",
    "@tanstack/solid-virtual": "^3.13.13",
    "@thisbeyond/solid-select": "^0.15.0",
    "corvu": "^0.7.2",
    "lucide-solid": "^0.561.0",
    "marked": "^17.0.1",
    "monaco-editor": "^0.55.1",
    "nanoid": "^5.1.6",
    "posthog-js": "^1.257.0",
    "shiki": "^3.20.0",
    "solid-floating-ui": "^0.3.1",
    "solid-js": "^1.9.9",
    "solid-transition-group": "^0.3.0",
    "tinykeys": "^3.0.0"
  }
}
