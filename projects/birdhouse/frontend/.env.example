# API Configuration

# Server port (set automatically by dev.ts based on BIRDHOUSE_BASE_PORT)
# Only needed if running frontend separately from dev.ts
# VITE_SERVER_PORT=50121

# Override the API base URL (optional)
# If not set, automatically detects based on current hostname and VITE_SERVER_PORT
# Examples:
# VITE_API_BASE=http://localhost:50121
# VITE_API_BASE=http://192.168.1.223:50121
# VITE_API_BASE=http://home.crayment.com:50121

# Server URL for logging (optional, defaults to API_BASE_URL)
# VITE_SERVER_URL=http://localhost:50121
#
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
