{
  "extends": ["stylelint-config-standard"],
  "plugins": ["stylelint-scss", "stylelint-declaration-strict-value"],
  "rules": {
    "scale-unlimited/declaration-strict-value": [
      [
        "color",
        "background-color",
        "border-color",
        "border-top-color",
        "border-right-color",
        "border-bottom-color",
        "border-left-color",
        "outline-color",
        "text-decoration-color"
      ],
      {
        "ignoreValues": [
          "inherit",
          "transparent",
          "currentColor",
          "initial",
          "unset"
        ]
      }
    ],
    "custom-property-pattern": null,
    "custom-property-empty-line-before": [
      "always",
      {
        "except": ["after-custom-property", "first-nested"],
        "ignore": ["after-comment", "inside-single-line-block"]
      }
    ],
    "declaration-empty-line-before": [
      "always",
      {
        "except": ["after-declaration", "first-nested"],
        "ignore": ["after-comment", "inside-single-line-block"]
      }
    ],
    "color-hex-length": "long",
    "color-named": "never",
    "color-no-invalid-hex": true,
    "declaration-block-no-duplicate-properties": [
      true,
      {
        "ignore": ["consecutive-duplicates-with-different-values"]
      }
    ],
    "declaration-block-no-shorthand-property-overrides": true,
    "property-no-vendor-prefix": null,
    "value-no-vendor-prefix": null,
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["global"]
      }
    ],
    "at-rule-no-unknown": null,
    "scss/at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["theme", "plugin"]
      }
    ],
    "comment-empty-line-before": [
      "always",
      {
        "except": ["first-nested"],
        "ignore": ["after-comment", "stylelint-commands"]
      }
    ],
    "rule-empty-line-before": [
      "always-multi-line",
      {
        "except": ["first-nested"],
        "ignore": ["after-comment"]
      }
    ],
    "selector-attribute-quotes": "always",
    "length-zero-no-unit": true,
    "shorthand-property-no-redundant-values": true,
    "declaration-block-single-line-max-declarations": 1,
    "number-max-precision": 4,
    "alpha-value-notation": "number",
    "color-function-notation": "legacy",
    "selector-class-pattern": null,
    "selector-id-pattern": null,
    "no-invalid-position-at-import-rule": null,
    "import-notation": null,
    "no-duplicate-selectors": true,
    "font-weight-notation": "numeric",
    "selector-max-id": 0,
    "media-feature-name-no-unknown": true,
    "selector-max-compound-selectors": 4,
    "selector-max-specificity": "0,4,0",
    "max-nesting-depth": 3,
    "selector-max-universal": 1,
    "time-min-milliseconds": 100,
    "declaration-no-important": true,
    "selector-max-attribute": 2,
    "selector-max-combinators": 3,
    "selector-max-type": 3,
    "selector-max-class": 5,
    "selector-max-pseudo-class": 3,
    "unit-disallowed-list": ["px"]
  },
  "ignoreFiles": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "**/*.js",
    "**/*.ts",
    "**/*.tsx"
  ],
  "overrides": [
    {
      "files": ["src/styles/themes/*.css"],
      "rules": {
        "custom-property-pattern": [
          "^theme-[a-z][a-z0-9]*(-[a-z0-9]+)*$",
          {
            "message": "Theme files must use variables following the pattern --theme-* (e.g., --theme-accent, --theme-text-primary)"
          }
        ]
      }
    }
  ]
}
