# Base port for Birdhouse instance (all other ports computed from this)
#
# Dev mode (bun run dev):  Frontend=BASE, Server=BASE+1, OpenCode=BASE+11
#   Example: 50120 → Frontend: 50120, Server: 50121, OpenCode: 50131-50230
#
# Production mode (CLI):   Server=BASE (serves frontend), OpenCode=BASE+10
#   Example: 50100 → Server: 50100 (with frontend), OpenCode: 50110-50209
#
BIRDHOUSE_BASE_PORT=50120

# Data database path (workspace registry, OpenCode tracking)
# Use different paths for dev vs prod to isolate OpenCode instances between environments
# Default: ~/Library/Application Support/Birdhouse/data.db
# Dev example: ~/Library/Application Support/Birdhouse/data-dev.db
# BIRDHOUSE_DATA_DB_PATH=~/Library/Application Support/Birdhouse/data-dev.db

# OpenCode configuration
#
# DEV MODE (recommended for development):
#   Set OPENCODE_PATH to the Birdhouse-flavored OpenCode fork root:
#     git clone git@github.com:Birdhouse-Labs/opencode.git
#     cd opencode && git checkout birdhouse
#   Server will run OpenCode from source using: bun run src/index.ts serve
#   BIRDHOUSE_OPENCODE_BIN not needed in dev mode
OPENCODE_PATH=/path/to/opencode
#
# PRODUCTION MODE (CLI / deployed environments):
#   Set BIRDHOUSE_OPENCODE_BIN to the compiled OpenCode binary
#   Example: /usr/local/bin/opencode or /path/to/opencode/bin/opencode
#   Leave OPENCODE_PATH unset or remove it
# BIRDHOUSE_OPENCODE_BIN=/path/to/opencode/bin/opencode

# Optional: comma-separated hostnames allowed to access the dev/preview server
# Useful when accessing Birdhouse from a custom domain or local network hostname
# When not set, Vite's default allowedHosts behavior applies (localhost only)
# Example: home.example.com,tablet.local
# BIRDHOUSE_ALLOWED_HOSTS=
