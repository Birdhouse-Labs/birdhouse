# Supabase Configuration
# Get these values from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

POSTHOG_PUBLIC_KEY=your-posthog-public-key
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase public anon key (safe to expose in client-side code)
SUPABASE_ANON_KEY=your-anon-key-here
HOST=http://localhost:3000
