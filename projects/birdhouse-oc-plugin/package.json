{
  "name": "birdhouse-oc-plugin",
  "version": "0.0.1",
  "description": "Birdhouse OpenCode plugin - exposes agent management tools (create, read, reply)",
  "main": "dist/plugin.js",
  "types": "dist/plugin.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun test && bun run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "birdhouse",
    "opencode",
    "plugin",
    "agents",
    "tools"
  ],
  "author": "Crayment",
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.15.18"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^0.15.31",
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
